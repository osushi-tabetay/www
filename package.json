{
  "name": "osushi-gallary",
  "version": "1.0.0",
  "description": "Illustrator portfolio site built with Astro and TypeScript.",
  "scripts": {
    "dev": "astro dev",
    "dev:contact": "wrangler dev --config wrangler.contact.jsonc",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "pnpm deploy:site",
    "deploy:site": "pnpm build && wrangler pages deploy dist --project-name osushi-gallary",
    "deploy:contact": "wrangler deploy --config wrangler.contact.jsonc",
    "deploy:contact:dry-run": "wrangler deploy --config wrangler.contact.jsonc --dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^6.4.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
