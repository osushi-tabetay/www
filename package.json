{
  "name": "osushi-gallary",
  "version": "1.0.0",
  "description": "Illustrator portfolio site built with Astro and TypeScript.",
  "scripts": {
    "dev": "astro dev",
    "dev:contact": "pnpm --dir contact-worker dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "deploy": "pnpm deploy:site",
    "deploy:site": "pnpm build && wrangler pages deploy dist --project-name osushi-gallary",
    "deploy:contact": "pnpm --dir contact-worker deploy",
    "deploy:contact:dry-run": "pnpm --dir contact-worker deploy:dry-run"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.6.0",
      "onFail": "download"
    }
  },
  "type": "module",
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "astro": "^6.4.6",
    "typescript": "^6.0.3",
    "wrangler": "^4.100.0"
  }
}
