---
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkCard from "../components/WorkCard.astro";
import { categories, works } from "../data/portfolio";
import { getCollection } from "astro:content";

const pageTitle = "Osushi Gallery | TRPG Illustrator Portfolio";
const pageDescription = "仄暗い物語とキャラクターをまとめたイラストポートフォリオ。";
const contactEndpoint = import.meta.env.PUBLIC_CONTACT_ENDPOINT ?? "/contact";
const allPosts = await getCollection("blog");
const posts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime()).slice(0, 3);
const stats = [
  { label: "works", value: String(works.length) },
  { label: "series", value: String(works.filter((work) => work.category === "series").length) },
  { label: "notes", value: String(allPosts.length) },
];
const postPath = (id: string) => `/blog/${id.replace(/\.md$/, "")}/`;
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <header class="site-header">
    <a class="brand" href="#top" aria-label="Osushi Gallery home">
      <img class="brand__mark" src="/assets/icon.jpg" alt="" width="40" height="40" />
      <span>Osushi Gallery</span>
    </a>
    <nav class="site-nav" aria-label="Primary navigation">
      <a href="#works">Works</a>
      <a href="#profile">About</a>
    </nav>
  </header>

  <main id="top">
    <section class="hero" aria-labelledby="hero-title">
      <img class="hero__image" src="/assets/hero-coc-bright.png" alt="" loading="eager" decoding="async" />
      <div class="hero__content">
        <p class="eyebrow">Illustration / Character</p>
        <h1 id="hero-title">Quiet Archive</h1>
        <p>仄暗いキャラクターと情景。</p>
        <div class="hero__actions">
          <a class="button button--primary" href="#works">Works</a>
          <a class="button button--ghost" href="#profile">About</a>
        </div>
      </div>
      <button class="hero__panel contact-launch" type="button" data-open-contact aria-haspopup="dialog">
        <span>Contact</span>
        <strong>Mail</strong>
        <small>open form</small>
      </button>
    </section>

    <section class="stats-band" aria-label="Portfolio statistics">
      {stats.map((stat) => (
        <div>
          <strong>{stat.value}</strong>
          <span>{stat.label}</span>
        </div>
      ))}
    </section>

    <section class="section" id="works" aria-labelledby="works-title">
      <div class="section__head">
        <div>
          <p class="eyebrow">Selected Works</p>
          <h2 id="works-title">Works</h2>
        </div>
        <div class="filter-bar" role="tablist" aria-label="Work filters">
          {categories.map((category) => (
            <button
              type="button"
              class="filter-button"
              role="tab"
              aria-selected={category.id === "all" ? "true" : "false"}
              data-filter={category.id}
            >
              {category.label}
            </button>
          ))}
        </div>
        <div class="work-controls" aria-label="Work list controls">
          <button class="work-scroll-button" type="button" data-work-scroll="prev" aria-label="Scroll works left">
            ‹
          </button>
          <button class="work-scroll-button" type="button" data-work-scroll="next" aria-label="Scroll works right">
            ›
          </button>
        </div>
      </div>

      <div class="work-grid" data-work-grid>
        {works.map((work) => <WorkCard work={work} />)}
      </div>
    </section>

    <section class="process" aria-labelledby="process-title">
      <div>
        <p class="eyebrow">Notes</p>
        <h2 id="process-title">Notes</h2>
        <a class="text-link" href="/blog/">All notes</a>
      </div>
      <div class="note-list">
        {posts.map((post) => (
          <a class="note-row" href={postPath(post.id)}>
            <time datetime={post.data.date.toISOString()}>{post.data.date.getFullYear()}</time>
            <strong>{post.data.title}</strong>
            <span>{post.data.description}</span>
          </a>
        ))}
      </div>
    </section>

    <section class="section profile" id="profile" aria-labelledby="profile-title">
      <div>
        <p class="eyebrow">Profile</p>
        <h2 id="profile-title">About</h2>
      </div>
      <p>
        くすんだ色、やわらかな線、少しだけ不穏な余白。
        キャラクターがそこにいる気配を、静かに残します。
      </p>
      <ul class="profile__list" aria-label="Specialties">
        <li>characters</li>
        <li>scenes</li>
        <li>objects</li>
      </ul>
    </section>
  </main>

  <dialog class="work-dialog" data-work-dialog aria-labelledby="dialog-title">
    <button class="work-dialog__close" type="button" data-close-dialog aria-label="Close">×</button>
    <div class="work-dialog__art" data-dialog-art>
      <img class="work-dialog__image" data-dialog-image src="" alt="" style="display: none;" />
    </div>
    <div class="work-dialog__body">
      <p class="eyebrow" data-dialog-meta></p>
      <h2 id="dialog-title" data-dialog-title></h2>
      <p data-dialog-summary></p>
      <p data-dialog-detail></p>
      <ul class="tag-list" data-dialog-tags></ul>
    </div>
  </dialog>

  <dialog class="contact-dialog" data-contact-dialog aria-labelledby="contact-title">
    <button class="work-dialog__close" type="button" data-close-contact aria-label="Close">×</button>
    <form class="contact-form" data-contact-form data-endpoint={contactEndpoint}>
      <p class="eyebrow">Contact</p>
      <h2 id="contact-title">Mail</h2>
      <label>
        <span>Name</span>
        <input name="name" type="text" autocomplete="name" required maxlength="80" />
      </label>
      <label>
        <span>Email</span>
        <input name="email" type="email" autocomplete="email" required maxlength="160" />
      </label>
      <label>
        <span>Message</span>
        <textarea name="message" required minlength="10" maxlength="4000" rows="6"></textarea>
      </label>
      <label class="contact-form__trap">
        <span>Website</span>
        <input name="website" type="text" tabindex="-1" autocomplete="off" />
      </label>
      <button class="button button--primary" type="submit">Send</button>
      <p class="contact-form__status" data-contact-status aria-live="polite"></p>
    </form>
  </dialog>

  <script id="portfolio-data" type="application/json" set:html={JSON.stringify(works)} is:inline />
  <script>
    import "../scripts/portfolio";
  </script>
</BaseLayout>
