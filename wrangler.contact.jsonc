{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "osushi-gallery-contact",
  "main": "workers/contact.ts",
  "compatibility_date": "2026-06-13",
  "send_email": [
    {
      "name": "EMAIL",
      "remote": true
    }
